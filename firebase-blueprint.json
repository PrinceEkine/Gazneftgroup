{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and master profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "EmailAccount": {
      "title": "Email Account",
      "description": "Configuration for a linked email account (IMAP/SMTP or OAuth2).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerUid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "provider": { "type": "string", "enum": ["gmail", "outlook", "custom"] },
        "imapHost": { "type": "string" },
        "imapPort": { "type": "number" },
        "smtpHost": { "type": "string" },
        "smtpPort": { "type": "number" },
        "label": { "type": "string" },
        "color": { "type": "string" },
        "authType": { "type": "string", "enum": ["password", "oauth2"] },
        "accessToken": { "type": "string" },
        "refreshToken": { "type": "string" },
        "expiryDate": { "type": "number" },
        "lastSynced": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerUid", "email", "provider"]
    },
    "EmailMessage": {
      "title": "Email Message",
      "description": "Metadata and cached content for an email message.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "accountId": { "type": "string" },
        "ownerUid": { "type": "string" },
        "subject": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "array", "items": { "type": "string" } },
        "date": { "type": "string", "format": "date-time" },
        "snippet": { "type": "string" },
        "body": { "type": "string" },
        "isRead": { "type": "boolean" },
        "folder": { "type": "string", "enum": ["inbox", "sent", "drafts", "trash", "spam"] },
        "hasAttachments": { "type": "boolean" }
      },
      "required": ["accountId", "ownerUid", "subject", "from", "date"]
    },
    "EmailTemplate": {
      "title": "Email Template",
      "description": "Reusable email templates for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "subject", "body"]
    },
    "EmailDraft": {
      "title": "Email Draft",
      "description": "Unsent email drafts saved by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "accountId": { "type": "string" },
        "userId": { "type": "string" },
        "to": { "type": "string" },
        "replyTo": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["draft"] }
      },
      "required": ["userId", "accountId"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/users/{uid}/accounts/{accountId}": {
      "schema": "EmailAccount",
      "description": "Linked email accounts for a user."
    },
    "/users/{uid}/messages/{messageId}": {
      "schema": "EmailMessage",
      "description": "Cached email messages for a user."
    },
    "/users/{uid}/templates/{templateId}": {
      "schema": "EmailTemplate",
      "description": "Reusable email templates for a user."
    },
    "/users/{uid}/drafts/{draftId}": {
      "schema": "EmailDraft",
      "description": "Unsent email drafts for a user."
    }
  }
}
